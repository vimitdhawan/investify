{
  "name": "investify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "rm -rf node_modules/thread-stream/test node_modules/thread-stream/*.md node_modules/thread-stream/bench.js node_modules/thread-stream/eslint.config.js node_modules/thread-stream/.github node_modules/thread-stream/.husky node_modules/thread-stream/LICENSE node_modules/thread-stream/tsconfig.json || true",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "test:ci": "npx jest --ci --coverage --maxWorkers=2",
    "test:debug": "node --inspect-brk ./node_modules/.bin/jest --runInBand",
    "lint": "npx eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "npx eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "type-check": "npx tsc --noEmit",
    "pre-commit": "npm run type-check && npm run lint && npm run format:check",
    "setup:hooks": "bash scripts/setup-git-hooks.sh",
    "check-all": "npm run type-check && npm run lint && npm run format:check && npm run test:coverage",
    "ci:install": "npm ci --legacy-peer-deps",
    "ci:validate": "npm run type-check && npm run lint && npm run format:check && npm run test:ci && npm run build",
    "emulators:start": "npx firebase emulators:start --import=./firebase-data --export-on-exit=./firebase-data",
    "ingest:schemes": "node --env-file=.env.local -r tsx scripts/ingest-schemes.ts",
    "ingest:portfolio": "node --env-file=.env.local -r tsx scripts/ingest-portfolio.ts",
    "ingest:holdings": "node --env-file=.env.local -r tsx scripts/ingest-holdings.ts",
    "nav:sync": "node --env-file=.env.local -r tsx scripts/nav-crawler/index.ts",
    "nav:import": "node --env-file=.env.local -r tsx scripts/nav-crawler/import-historical.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.6.0",
    "jose": "^6.1.2",
    "lucide-react": "^0.554.0",
    "next": "16.0.3",
    "next-themes": "^0.4.6",
    "parquetjs": "^0.11.2",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-day-picker": "^9.12.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.66.1",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "xirr": "^1.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/mcp": "^0.0.68",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/parquetjs": "^0.10.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "firebase-tools": "^15.10.0",
    "hyparquet": "^1.25.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "msw": "^2.12.11",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.11.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
