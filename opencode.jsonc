{
  "$schema": "https://opencode.ai/config.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(rm *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)"
    ],
    "deny": [
      "Bash(git push --force-with-lease origin main *)",
      "Bash(git push --force origin main *)",
      "Read(.env.local)"
    ]
  },
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
