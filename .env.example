# Firebase Configuration
# Project ID for your Firebase project
FIREBASE_PROJECT_ID=your-project-id

# Firebase Web API Key for authentication
FIREBASE_WEB_API_KEY=your-web-api-key

# Emulator Configuration (for local development and testing)
# Set to 'true' to use Firebase emulators instead of production
FIREBASE_EMULATOR_MODE=false

# Firebase Auth Emulator Host (default: localhost:9099)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Firebase Storage Emulator Host (default: localhost:9199)
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Firebase Project ID for emulator mode
FIREBASE_EMULATOR_PROJECT_ID=demo-investify

# Next.js Configuration
# Add any additional Next.js specific environment variables here
