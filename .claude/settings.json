{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(rm *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)"
    ],
    "deny": [
      "Bash(git push --force-with-lease origin main *)",
      "Bash(git push --force origin main *)",
      "Read(.env.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo 'graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.' || true"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["next-devtools", "shadcn", "playwright"]
}
