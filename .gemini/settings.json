{
  "security": {
    "enablePermanentToolApproval": true
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(rm *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git checkout *)"
    ],
    "deny": [
      "Bash(git push --force-with-lease origin main *)",
      "Bash(git push --force origin main *)",
      "Read(.env.local)"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "next-devtools": {
      "command": "npx",
      "args": ["next-devtools-mcp@latest"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    }
  }
}
